{
  "name": "aegis-protocol-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "AEGIS Protocol TypeScript SDK monorepo",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "generate:abis": "pnpm --filter @aegis-protocol/abis generate"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.16.1",
      "brace-expansion": "5.0.5",
      "follow-redirects": "1.16.0",
      "handlebars": "4.7.9",
      "langsmith": "0.7.1",
      "uuid": "13.0.1"
    }
  },
  "packageManager": "pnpm@9.15.4"
}
